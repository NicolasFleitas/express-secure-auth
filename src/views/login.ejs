<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | The Huddle</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <div class="login-card">
        <h1>Bienvenido</h1>
        <p class="subtitle">Ingresa a tu cuenta</p>

        <form id="loginForm" data-csrf="<%= csrfToken %>">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="tu@email.com" required>
            </div>

            <div class="form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>

            <div class="form-group">
                <label for="sessionType">Tipo de Sesión</label>
                <select id="sessionType" name="sessionType">
                    <option value="cookie">Persistente (Cookie)</option>
                    <option value="jwt">Sin Estado (JWT Puro)</option>
                </select>
            </div>

            <button type="submit" class="btn" id="submitBtn">
                <span class="loader" id="loader"></span>
                <span>Iniciar Sesión</span>
            </button>
        </form>

        <div id="message" class="message"></div>
    </div>

    <script src="/js/login.js"></script>
</body>

</html>