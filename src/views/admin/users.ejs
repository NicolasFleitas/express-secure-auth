<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('../partials/head', { title: 'Panel de Administración' , extraStyles: ['/css/admin.css'], csrfToken:
        csrfToken }) %>
</head>

<body>
    <div class="admin-container">
        <header class="admin-header">
            <div>
                <h1>Panel de Control</h1>
                <p style="color: var(--text-muted); font-size: 14px;">Bienvenido, <%= user.email %>
                </p>
            </div>
            <div class="nav-links">
                <a href="/api/auth/profile" class="nav-link">Mi Perfil</a>
                <a href="/" class="nav-link">Inicio</a>
            </div>
        </header>

        <%- include('../partials/messages', { message: message, error: error }) %>

            <section class="section-card">
                <h2 class="section-title">
                    <span>👥</span> Gestión de Usuarios
                </h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Rol</th>
                                <th>ID</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(u=> { %>
                                <tr>
                                    <td>
                                        <%= u.email %>
                                    </td>
                                    <td>
                                        <span class="role-badge" style="margin-bottom: 0;">
                                            <%= u.role %>
                                        </span>
                                    </td>
                                    <td style="color: var(--text-muted); font-family: monospace;">
                                        <%= u.id %>
                                    </td>
                                    <td>
                                        <% if (u.id !==user.id) { %>
                                            <button class="delete-btn" data-user-id="<%= u.id %>">Eliminar</button>
                                            <% } else { %>
                                                <span
                                                    style="color: var(--text-muted); font-style: italic; font-size: 12px;">(Tú)</span>
                                                <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="section-card">
                <h2 class="section-title">
                    <span>🛡️</span> Intentos de Inicio de Sesión
                </h2>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>IP</th>
                                <th>Fecha</th>
                                <th>Resultado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% loginAttempts.forEach(attempt=> { %>
                                <tr>
                                    <td>
                                        <%= attempt.email %>
                                    </td>
                                    <td>
                                        <%= attempt.ip_address %>
                                    </td>
                                    <td>
                                        <%= new Date(attempt.created_at).toLocaleString() %>
                                    </td>
                                    <td>
                                        <span
                                            class="status-badge <%= attempt.success ? 'status-success' : 'status-failed' %>">
                                            <%= attempt.success ? 'EXITOSO' : 'FALLIDO' %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>
    </div>

    <script type="module" src="/js/admin.js"></script>
</body>

</html>