<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('partials/head', { title: 'Error' }) %>
</head>

<body>
    <div class="login-card">
        <h1 style="color: var(--danger);">¡Ups! Algo salió mal</h1>
        <p class="subtitle">Lo sentimos, ha ocurrido un error inesperado.</p>

        <div class="message error" style="display: block; margin-top: 20px;">
            <%= typeof error !=='undefined' ? error : 'Error interno del servidor' %>
        </div>

        <div class="actions" style="margin-top: 30px;">
            <a href="/" class="btn" style="text-decoration: none; text-align: center; display: block;">Volver al
                inicio</a>
        </div>
    </div>
</body>

</html>