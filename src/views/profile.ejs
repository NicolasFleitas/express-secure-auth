<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('partials/head', { title: 'Perfil' }) %>
</head>

<body>
    <div class="profile-card">
        <div class="avatar">
            <%= (user.email && user.email[0].toUpperCase()) || 'U' %>
        </div>
        <h1>Mi Perfil</h1>
        <div class="role-badge">
            <%= user.role || 'Usuario' %>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Identificador (Cifrado)</span>
                <span class="info-value">
                    <%= user.id %>
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Correo Electrónico</span>
                <span class="info-value">
                    <%= user.email %>
                </span>
            </div>
        </div>

        <div class="actions">
            <% if (user.role==='admin' ) { %>
                <a href="/api/admin/users" class="btn btn-primary"
                    style="background-color: var(--success); margin-bottom: 10px;">Panel Admin</a>
                <% } %>
                    <a href="/api/auth/login" class="btn btn-primary">Volver al Login</a>
                    <button id="logoutBtn" class="btn btn-danger">Cerrar Sesión</button>
        </div>
    </div>

    <script src="/js/profile.js"></script>
</body>

</html>